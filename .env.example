# ── Database ──────────────────────────────────────────────────────────────────
# taxlegal app DB — schema 'taxlegal' will be auto-created inside this database
DATABASE_URL=postgresql+asyncpg://user:password@10.0.1.11:5432/taxlegal

# dbvntax — read-only, existing tax law database (same host)
DBVNTAX_DATABASE_URL=postgresql+asyncpg://user:password@10.0.1.11:5432/postgres

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-32-char-key-here
ADMIN_EMAIL=vuhoang04@gmail.com
ADMIN_PASSWORD=Admin@123456

# ── AI Providers (set those you have) ────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_MODEL=deepseek-chat

# OpenRouter models (optional, add up to 4)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL1=qwen/qwen3-72b
OPENROUTER_MODEL2=
OPENROUTER_MODEL3=
OPENROUTER_MODEL4=

# ── Web Search (Perplexity Sonar) ─────────────────────────────────────────────
# Used by agents for fact/legal verification
PERPLEXITY_API_KEY=pplx-...
PERPLEXITY_SEARCH_MODEL=sonar
